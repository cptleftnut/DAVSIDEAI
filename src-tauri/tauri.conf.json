{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DAVSIDE AI",
  "version": "0.3.0",
  "identifier": "com.davside.ai"
},
  "build": {
    "beforeBuildCommand": "npm run build", 
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../frontend/dist"
  },
}
  "build": {
    "frontendDist": "/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "capabilities": ["default"]
    },
    "windows": [
      {
        "title": "DAVSIDE AI",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 24,
      "versionCode": 3
    }
  },
  "plugins": {
    "store": {}
  }
}
